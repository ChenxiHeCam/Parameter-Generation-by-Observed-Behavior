\@writefile{lof}{\contentsline {figure}{\numberline {8}{\ignorespaces \textbf  {Same-species soft-prior initialisation transfer between sibling simulators.} \emph  {A}, flybody self-prior: a FlyGym$\to $flybody same-species prior lowers the CMA-ES loss $9.3\times $ (random init $0.01085\to $ prior $0.001166$; log scale). \emph  {B}, BAAIWorm$\to $modWorm: held-out behaviour distance to real OWMD ($W_1$; lower is more real) for the simulator's own default init vs.\ a cross-sim soft prior, over $N{=}16$ held-out starts (own default $3.37\to $ cross-sim prior $2.29$; $13/16$ starts improved, Wilcoxon $p{=}0.025$; error bars $95\%$ CI).}}{21}{figure.8}\protected@file@percent }
