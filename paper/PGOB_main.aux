\@writefile{lof}{\contentsline {figure}{\numberline {7}{\ignorespaces \textbf  {The PGOB formulation instantiated with an amortized neural posterior (NPE-MAF).} \emph  {A}, posterior-predictive reproduction of each simulator's own behaviour. \emph  {Left:} modWorm ($30$-d, $N{=}14{,}993$ simulations) -- mean absolute observable difference between the posterior-predictive behaviour and the ground-truth target ($1.4\times 10^{-3}$). \emph  {Right:} FlyGym v2 ($48$-d, $N{=}6{,}000$) -- relative error of the posterior mean to the canonical actuator gains ($0.018$); the two simulators use different native generation metrics and are plotted on their own scales. \emph  {B}, density-estimator comparison on the same simulation pools: held-out negative log-probability (lower is a better fit) for a neural spline flow (NSF), the masked autoregressive flow (MAF), and a mixture-density network (MDN), giving NSF $>$ MAF $>$ MDN on both simulators.}}{18}{figure.7}\protected@file@percent }
\newlabel{fig:sbi_engine}{{7}{18}{\textbf {The PGOB formulation instantiated with an amortized neural posterior (NPE-MAF).} \emph {A}, posterior-predictive reproduction of each simulator's own behaviour. \emph {Left:} modWorm ($30$-d, $N{=}14{,}993$ simulations) -- mean absolute observable difference between the posterior-predictive behaviour and the ground-truth target ($1.4\times 10^{-3}$). \emph {Right:} FlyGym v2 ($48$-d, $N{=}6{,}000$) -- relative error of the posterior mean to the canonical actuator gains ($0.018$); the two simulators use different native generation metrics and are plotted on their own scales. \emph {B}, density-estimator comparison on the same simulation pools: held-out negative log-probability (lower is a better fit) for a neural spline flow (NSF), the masked autoregressive flow (MAF), and a mixture-density network (MDN), giving NSF $>$ MAF $>$ MDN on both simulators}{figure.7}{}}
