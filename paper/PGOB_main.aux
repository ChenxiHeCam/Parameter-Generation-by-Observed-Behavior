\@writefile{lof}{\contentsline {figure}{\numberline {5}{\ignorespaces \textbf  {Extended-budget PGOB-hybrid fine-tune.} Held-out distance to real biology along the real fine-tune trajectory, each curve normalised to its own warm-start level ($100\%$; dotted line); stars mark the held-out minimum. The warm-start already sits near the substrate's best reachable real fit, so the additional fine-tune gain is small and bounded by the substrate, not by the optimiser (split-level table in SI \S  S4.23). Both arms use a genuine forward model scored on a held-out real reference.}}{14}{figure.5}\protected@file@percent }
\newlabel{fig:hybrid_extended}{{5}{14}{\textbf {Extended-budget PGOB-hybrid fine-tune.} Held-out distance to real biology along the real fine-tune trajectory, each curve normalised to its own warm-start level ($100\%$; dotted line); stars mark the held-out minimum. The warm-start already sits near the substrate's best reachable real fit, so the additional fine-tune gain is small and bounded by the substrate, not by the optimiser (split-level table in SI \S S4.23). Both arms use a genuine forward model scored on a held-out real reference}{figure.5}{}}
\@writefile{toc}{\contentsline {subsection}{\numberline {3.5}Cross-simulator parity against real public references}{14}{subsection.3.5}\protected@file@percent }
